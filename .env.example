# CognifyAI - Environment Configuration Template

# Server Port
PORT=5000

# Secret key for signing local JWT tokens (fallback and internal communication)
JWT_SECRET=your_jwt_secret_key_here

# Supabase Configuration
# Retrieve these credentials from your Supabase Dashboard: Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# SMTP Configuration (for password reset and email triggers)
# Configure SMTP details for transactional notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_EMAIL=your-email@domain.com
SMTP_PASSWORD=your-app-password
